set(LOG_LEVEL_VALUE)

if(LOG_LEVEL STREQUAL "DEBUG")
    set(LOG_LEVEL_VALUE 4)
elseif(LOG_LEVEL STREQUAL "INFO")
    set(LOG_LEVEL_VALUE 3)
elseif(LOG_LEVEL STREQUAL "WARN")
    set(LOG_LEVEL_VALUE 2)
elseif(LOG_LEVEL STREQUAL "ERROR")
    set(LOG_LEVEL_VALUE 1)
elseif(LOG_LEVEL STREQUAL "OFF")
    set(LOG_LEVEL_VALUE 0)
else()
    message(FATAL_ERROR "LOG_LEVEL not set.")
endif()

add_compile_definitions(LOG_LEVEL=${LOG_LEVEL_VALUE})